# ─────────────────────────────────────────────────────────────
# Duplicate Payment Detection — Environment Configuration
# Copy this file to .env and fill in values before running.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=payments_user
POSTGRES_PASSWORD=payments_pass
POSTGRES_DB=payments_dw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=86400       # 24 hours idempotency key TTL

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=payments.raw
KAFKA_TOPIC_DECISIONS=payments.decisions
KAFKA_TOPIC_DEADLETTER=payments.deadletter
KAFKA_CONSUMER_GROUP=dedup-flink-group

# Airflow
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Simulator settings
SIMULATOR_EVENTS_PER_SECOND=50
SIMULATOR_DUPLICATE_RATE=0.15    # 15% of events are duplicate retries
SIMULATOR_TOTAL_EVENTS=10000
